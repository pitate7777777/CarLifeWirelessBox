# EditorConfig — 统一代码风格
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.kt]
indent_size = 4
max_line_length = 140

[*.{xml,json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.gradle.kts]
indent_size = 4

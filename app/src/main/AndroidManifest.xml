<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ==================== 网络与连接权限 ==================== -->
    <!-- WiFi 相关 -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        tools:targetApi="33" />

    <!-- 热点相关 (Android 8.0+) -->
    <uses-permission android:name="android.permission.TETHER_PRIVILEGED"
        tools:ignore="ProtectedPermissions" />

    <!-- USB -->
    <uses-permission android:name="android.permission.USB_PERMISSION" />

    <!-- 网络 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- mDNS / NSD 服务发现 -->

    <!-- ==================== 媒体与投屏权限 ==================== -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAPTURE_VIDEO_OUTPUT"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.CAPTURE_AUDIO_OUTPUT"
        tools:ignore="ProtectedPermissions" />

    <!-- ==================== 系统权限 ==================== -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:ignore="ForegroundServicesPolicy" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"
        tools:targetApi="29" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="33" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.REORDER_TASKS" />

    <!-- ==================== 存储权限 ==================== -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <!-- MANAGE_EXTERNAL_STORAGE 已移除：项目使用 app-specific 存储，不需要此权限 -->

    <!-- ==================== 硬件特性 ==================== -->
    <uses-feature
        android:name="android.hardware.wifi"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.audio.output"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.screen.landscape"
        android:required="false" />

    <application
        android:name=".CarLifeApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CarLifeWirelessBox"
        android:foregroundServiceType="mediaProjection"
        tools:targetApi="29">

        <!-- ==================== 主 Activity ==================== -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:windowSoftInputMode="stateAlwaysHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ==================== CarLife 核心服务 ==================== -->
        <!-- 连接服务：负责 WiFi AP/热点 启动、mDNS 广播、TCP 监听 -->
        <service
            android:name=".service.ConnectionService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- 协议服务：Protobuf 消息解析、分发、心跳管理 -->
        <service
            android:name=".service.ProtocolService"
            android:enabled="true"
            android:exported="false" />

        <!-- 视频服务：屏幕采集、编码 (H.264/H.265)、帧传输 -->
        <service
            android:name=".service.VideoService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- 音频服务：音频采集、编码 (AAC/Opus)、流传输 -->
        <service
            android:name=".service.AudioService"
            android:enabled="true"
            android:exported="false" />

        <!-- 触摸服务：触摸事件接收、坐标转换、事件注入 -->
        <service
            android:name=".service.TouchService"
            android:enabled="true"
            android:exported="false" />

        <!-- 无障碍服务：触摸手势注入（需用户在系统设置中手动开启） -->
        <service
            android:name=".service.CarAccessibilityService"
            android:enabled="true"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- ==================== 设置 Activity ==================== -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <!-- ==================== 日志查看 Activity ==================== -->
        <activity
            android:name=".ui.LogViewerActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <!-- ==================== 网络诊断 Activity ==================== -->
        <activity
            android:name=".ui.NetworkDiagActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <!-- ==================== USB 连接引导 Activity ==================== -->
        <activity
            android:name=".ui.UsbGuideActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <!-- ==================== WiFi 连接引导 Activity ==================== -->
        <activity
            android:name=".ui.WifiGuideActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <!-- ==================== Receiver ==================== -->
        <!-- 开机自启 (可选) -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- WiFi 状态变化监听 -->
        <receiver
            android:name=".receiver.WifiStateReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.wifi.WIFI_STATE_CHANGED" />
                <action android:name="android.net.wifi.STATE_CHANGE" />
            </intent-filter>
        </receiver>

        <!--FileProvider：用于分享日志文件 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>

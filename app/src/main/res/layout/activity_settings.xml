<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/car_preset_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerCarPreset"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/video_resolution"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerResolution"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/video_bitrate"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seekbarBitrate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:max="8000"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvBitrateValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="2000 kbps"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/video_framerate"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerFramerate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/audio_sample_rate_label"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerSampleRate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tcp_port"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etPort"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:inputType="number" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/phone_b_ip_label"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etPhoneBIp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="8dp"
            android:inputType="text"
            android:hint="@string/phone_b_ip_hint" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/phone_b_ip_helper"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/save" />

    </LinearLayout>
</ScrollView>

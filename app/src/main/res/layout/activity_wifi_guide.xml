<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:title="@string/wifi_guide_title"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp">

            <!-- 标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/wifi_guide_heading"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/wifi_guide_desc"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- 步骤指示器 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <View
                    android:id="@+id/dot_step_0"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/step_dot"
                    android:backgroundTint="@color/step_dot_active" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="2dp"
                    android:background="@color/step_connector" />

                <View
                    android:id="@+id/dot_step_1"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/step_dot"
                    android:backgroundTint="@color/step_dot_inactive" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="2dp"
                    android:background="@color/step_connector" />

                <View
                    android:id="@+id/dot_step_2"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/step_dot"
                    android:backgroundTint="@color/step_dot_inactive" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="2dp"
                    android:background="@color/step_connector" />

                <View
                    android:id="@+id/dot_step_3"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/step_dot"
                    android:backgroundTint="@color/step_dot_inactive" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="2dp"
                    android:background="@color/step_connector" />

                <View
                    android:id="@+id/dot_step_4"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/step_dot"
                    android:backgroundTint="@color/step_dot_inactive" />

            </LinearLayout>

            <!-- 步骤内容卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tv_step_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/wifi_step_1_title"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tv_step_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/wifi_step_1_desc"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- WiFi 连接信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/usb_connection_info"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_connection_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/usb_detecting"
                        android:textSize="13sp"
                        android:fontFamily="monospace" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 操作按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_wifi_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_open_wifi"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:icon="@drawable/ic_settings" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_hotspot_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_open_hotspot"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:icon="@drawable/ic_settings" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_retry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_refresh_status"
                android:layout_marginBottom="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_service"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_start_carlife"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_done"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_done"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:backgroundTint="@color/btn_done_bg" />

            <!-- 常见问题 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/tip_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/faq_title"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/wifi_faq"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
